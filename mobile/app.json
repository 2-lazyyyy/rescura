{
  "expo": {
    "name": "Rescura",
    "slug": "rescura-mobile",
    "scheme": "rescura",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rescura.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "location",
          "remote-notification",
          "fetch",
          "location",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.rescura.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-notifications",
      "expo-location",
      "expo-background-fetch",
      "expo-task-manager",
      "llama.rn",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0f5a7d3-668a-4f05-8558-d3195b99d574"
      }
    },
    "owner": "thwinkhantoo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e0f5a7d3-668a-4f05-8558-d3195b99d574"
    }
  }
}
